# Postgres — its own database, NOT shared with silver-glider-tickets or uht-app
DATABASE_URL=postgresql://localhost:5432/sge_dev

# Long random string; signs organizer session cookies and magic-link HMACs
SESSION_SECRET=

# Absolute base URL used in emails, QR codes, and .ics links
APP_URL=http://localhost:3100
PORT=3100
NODE_ENV=development

# Resend — leave RESEND_API_KEY empty in dev to log magic links to console
RESEND_API_KEY=
RESEND_FROM=events@silverglidertickets.com

# Cloudinary — cover image uploads (no fallbacks; required in production)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google Places autocomplete for venue search.
# Use a browser key restricted by HTTP referrer; supported names:
# GOOGLE_PLACES_API_KEY, GOOGLE_MAPS_API_KEY, or GOOGLE_MAPS_BROWSER_KEY.
GOOGLE_PLACES_API_KEY=

# Set false to disable the reminder cron locally
REMINDERS_ENABLED=true
